# ──────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000

# ──────────────────────────────────────────────
# SERVER
# ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
HTTPS_PORT=8443
TLS_CERT_PATH=./infra/ssl/cert.pem
TLS_KEY_PATH=./infra/ssl/key.pem

# ──────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ──────────────────────────────────────────────
POSTGRES_USER=boilerplate
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=boilerplate_dev
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Connection Pool Settings (Diesel r2d2)
# Tune these for high-concurrency scenarios
DB_POOL_SIZE=10                          # Max connections (default: 10)
DB_POOL_MIN_IDLE=2                       # Min idle connections (optional)
DB_POOL_MAX_LIFETIME_SECS=1800           # Max connection lifetime: 30 min (optional)
DB_POOL_IDLE_TIMEOUT_SECS=600            # Idle timeout: 10 min (optional)
DB_POOL_CONNECTION_TIMEOUT_SECS=10       # Connection timeout: 10 sec (default: 10)

# High-concurrency example (uncomment and adjust for production):
# DB_POOL_SIZE=50
# DB_POOL_MIN_IDLE=10
# DB_POOL_MAX_LIFETIME_SECS=3600
# DB_POOL_IDLE_TIMEOUT_SECS=300
# DB_POOL_CONNECTION_TIMEOUT_SECS=30

# ──────────────────────────────────────────────
# REDIS
# ──────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# Connection Pool Settings
REDIS_POOL_SIZE=10                       # Max connections (default: 10)

# ──────────────────────────────────────────────
# JWT / AUTHENTICATION
# ──────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_GENERATED_64_CHAR_BASE64_SECRET
JWT_ACCESS_EXPIRY_SECS=900           # 15 minutes
JWT_REFRESH_EXPIRY_SECS=2592000      # 30 days

# ──────────────────────────────────────────────
# SECURITY / ENCRYPTION
# ──────────────────────────────────────────────
# Master key for field-level encryption (AES-GCM, 32 bytes base64)
# Generate with: openssl rand -base64 32
MASTER_ENCRYPTION_KEY=REPLACE_WITH_GENERATED_32_BYTE_BASE64_KEY

# Blind index key for deterministic search (32 bytes base64)
# Generate with: openssl rand -base64 32
BLIND_INDEX_KEY=REPLACE_WITH_GENERATED_32_BYTE_BASE64_KEY

CURRENT_ENCRYPTION_KEY_VERSION=1

# Internal API keys for service-to-service communication (comma-separated)
INTERNAL_API_KEYS=

# CSRF secret key for signed CSRF tokens (32+ bytes)
# Generate with: openssl rand -base64 32
CSRF_SECRET_KEY=REPLACE_WITH_GENERATED_32_BYTE_BASE64_KEY

# Refresh token hash salt (HMAC-SHA256 key for hashing refresh tokens)
# Generate with: openssl rand -base64 32
REFRESH_TOKEN_HASH_SALT=REPLACE_WITH_GENERATED_32_BYTE_BASE64_KEY

# ──────────────────────────────────────────────
# EMAIL (Resend)
# ──────────────────────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME="Your App"

# ──────────────────────────────────────────────
# BUNNY.NET CDN / STORAGE
# ──────────────────────────────────────────────
BUNNY_STORAGE_ZONE=your-zone
BUNNY_STORAGE_KEY=your-key
BUNNY_CDN_URL=https://your-cdn.b-cdn.net
BUNNY_TOKEN_KEY=your-token-key

# Bunny.net Stream
BUNNY_STREAM_LIBRARY_ID=your-library-id
BUNNY_STREAM_KEY=your-stream-key
BUNNY_STREAM_WEBHOOK_SECRET=your-webhook-secret

# ──────────────────────────────────────────────
# BACKBLAZE B2
# ──────────────────────────────────────────────
B2_KEY_ID=your-key-id
B2_APPLICATION_KEY=your-application-key
B2_BUCKET_ID=your-bucket-id
B2_BUCKET_NAME=your-bucket-name
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com

# ──────────────────────────────────────────────
# STRIPE
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX

# ──────────────────────────────────────────────
# PLATFORM SETTINGS
# ──────────────────────────────────────────────
PLATFORM_COMMISSION_PERCENT=20.0
MIN_SUBSCRIPTION_PRICE_CENTS=500
MAX_SUBSCRIPTION_PRICE_CENTS=50000
MIN_WITHDRAWAL_AMOUNT_CENTS=2000

# ──────────────────────────────────────────────
# TOTP (2FA)
# ──────────────────────────────────────────────
TOTP_ISSUER="Your App"

# ──────────────────────────────────────────────
# FILE UPLOAD LIMITS
# ──────────────────────────────────────────────
MAX_VIDEO_SIZE_BYTES=10737418240    # 10 GB
MAX_PHOTO_SIZE_BYTES=52428800       # 50 MB
MAX_AUDIO_SIZE_BYTES=524288000      # 500 MB

# ──────────────────────────────────────────────
# REQUEST PAYLOAD LIMITS
# ──────────────────────────────────────────────
# JSON payload limit for application/json requests (default: 16 MB)
# Increase if your endpoints need to accept large JSON payloads
# For file upload metadata, 16 MB should be sufficient
JSON_PAYLOAD_LIMIT=16777216        # 16 MB

# Form payload limit for multipart/form-data requests (default: 20 MB)
# Increase if you need to accept large form submissions
FORM_PAYLOAD_LIMIT=20971520        # 20 MB

# ──────────────────────────────────────────────
# NUXT PUBLIC CONFIG
# ──────────────────────────────────────────────
# Public API base URL for client-side requests (CSR)
# When set, client-side fetches will go directly to this URL instead of
# going through the Nuxt/Nitro proxy. This reduces latency for non-SSR requests.
# Leave empty to use the default relative path (/api/v1) which goes through the proxy.
# Example: http://localhost:8080/api/v1
NUXT_PUBLIC_API_BASE=http://localhost:8080/api/v1

# RATE LIMITING
# ──────────────────────────────────────────────
# Enable/disable rate limiting globally (default: true)
# Set to false to disable rate limiting entirely
# RATE_LIMIT_ENABLED=true