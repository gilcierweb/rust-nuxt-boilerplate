###############################################################################
# SECURITY: This file is a TEMPLATE (.env.example) shown in the repository.   #
#                                                                             #
# DO NOT use the placeholder values below in any deployed environment.         #
#                                                                             #
# The following placeholders MUST be overridden before deployment:              #
#   * POSTGRES_PASSWORD, REDIS_PASSWORD                                       #
#   * JWT_SECRET, MASTER_ENCRYPTION_KEY, BLIND_INDEX_KEY                       #
#   * CSRF_SECRET_KEY, REFRESH_TOKEN_HASH_SALT                                #
#   * RESEND_API_KEY, STRIPE_*, BUNNY_*, B2_*                                 #
#                                                                             #
# In production, secrets SHOULD be provided via Docker secrets (see            #
# infra/secrets/README.md) — NOT env vars — for stronger isolation.            #
#                                                                             #
# The backend REJECTS placeholder values at startup if ENVIRONMENT !=          #
# "development"/"test"; this is enforced by `validate_required_secret_value()`   #
# in `backend/src/config/app_config.rs`.                                       #
###############################################################################

# ──────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000

# ──────────────────────────────────────────────
# SERVER
# ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
HTTPS_PORT=8443
TLS_CERT_PATH=./infra/ssl/cert.pem
TLS_KEY_PATH=./infra/ssl/key.pem

# ──────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ──────────────────────────────────────────────
POSTGRES_USER=boilerplate
# ⚠️  REQUIRED: replace with a 24+ char secret. Generate: `openssl rand -hex 16`
# ⚠️  The backend will REFUSE TO START if ENVIRONMENT != development/test and
# ⚠️  this remains `changeme_secure_password`.
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=boilerplate_dev
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Connection Pool Settings (Diesel r2d2)
# Tune these for high-concurrency scenarios
DB_POOL_SIZE=10                          # Max connections (default: 10)
DB_POOL_MIN_IDLE=2                       # Min idle connections (optional)
DB_POOL_MAX_LIFETIME_SECS=1800           # Max connection lifetime: 30 min (optional)
DB_POOL_IDLE_TIMEOUT_SECS=600            # Idle timeout: 10 min (optional)
DB_POOL_CONNECTION_TIMEOUT_SECS=10       # Connection timeout: 10 sec (default: 10)

# Statement Timeout (prevents long-running queries from blocking pool)
# Set to 0 to disable (not recommended for production)
DB_STATEMENT_TIMEOUT_SECS=30             # Query timeout: 30 sec (default: disabled)

# High-concurrency example (uncomment and adjust for production):
# DB_POOL_SIZE=50
# DB_POOL_MIN_IDLE=10
# DB_POOL_MAX_LIFETIME_SECS=3600
# DB_POOL_IDLE_TIMEOUT_SECS=300
# DB_POOL_CONNECTION_TIMEOUT_SECS=30

# ──────────────────────────────────────────────
# REDIS
# ──────────────────────────────────────────────
# Generate with: openssl rand -base64 24 | tr -d '/+=' | cut -c1-24
# ⚠️  REQUIRED in production. Backend REJECTS "changeme_*" unless ENVIRONMENT == development/test.
REDIS_PASSWORD=changeme_redis_password
# In development, REDIS_PASSWORD is optional. If set, REDIS_URL should use the URL-encoded password.
# Example with password: REDIS_URL=redis://:encoded_password@redis:6379
# Example without password: REDIS_URL=redis://redis:6379
REDIS_URL=redis://redis:6379

# Connection Pool Settings
# Recommended sizing based on workload:
# - Development: 10 (default)
# - Staging: 20-30
# - Production (low traffic): 50 (minimum)
# - Production (high traffic): 100 (recommended default)
# - Production (very high traffic): 150-200+
#
# Redis is used for: rate limiting, caching, session storage, token blacklisting
# Each concurrent request may use 1-2 Redis connections
REDIS_POOL_SIZE=10                       # Max connections (default: 10)

# ──────────────────────────────────────────────
# JWT / AUTHENTICATION
# ──────────────────────────────────────────────
# Generate with: openssl rand -base64 48
# ⚠️  JWT signing key. Must be 64+ chars base64. Required in production.
# ⚠️  Backend REJECTS "REPLACE_WITH_*" unless ENVIRONMENT == development/test.
JWT_SECRET=REPLACE_WITH_GENERATED_64_CHAR_BASE64_SECRET
JWT_ACCESS_EXPIRY_SECS=900           # 15 minutes
JWT_REFRESH_EXPIRY_SECS=2592000      # 30 days

# ──────────────────────────────────────────────
# SECURITY / ENCRYPTION
# ──────────────────────────────────────────────
# Master key for field-level encryption (AES-GCM, 32 bytes base64)
# Generate with: openssl rand -base64 32
# ⚠️  Controller for AES-GCM cipher. Required. Backend rejects placeholder.
MASTER_ENCRYPTION_KEY=REPLACE_WITH_GENERATED_32_BYTE_BASE64_KEY

# Blind index key for deterministic search (32 bytes base64)
# Generate with: openssl rand -base64 32
# ⚠️  Used for blind indexes on encrypted PII. Required. Backend rejects placeholder.
BLIND_INDEX_KEY=REPLACE_WITH_GENERATED_32_BYTE_BASE64_KEY

CURRENT_ENCRYPTION_KEY_VERSION=1

# Internal API keys for service-to-service communication (comma-separated)
INTERNAL_API_KEYS=

# CSRF secret key for signed CSRF tokens (32+ bytes)
# Generate with: openssl rand -base64 32
# ⚠️  Required. Used to sign CSRF tokens. Backend rejects placeholder.
CSRF_SECRET_KEY=REPLACE_WITH_GENERATED_32_BYTE_BASE64_KEY

# Refresh token hash salt (HMAC-SHA256 key for hashing refresh tokens)
# Generate with: openssl rand -base64 32
# ⚠️  Required. HMAC key for refresh-token digests. Backend rejects placeholder.
REFRESH_TOKEN_HASH_SALT=REPLACE_WITH_GENERATED_32_BYTE_BASE64_KEY

# ──────────────────────────────────────────────
# EMAIL (Resend)
# ──────────────────────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME="Your App"

# ──────────────────────────────────────────────
# BUNNY.NET CDN / STORAGE
# ──────────────────────────────────────────────
BUNNY_STORAGE_ZONE=your-zone
BUNNY_STORAGE_KEY=your-key
BUNNY_CDN_URL=https://your-cdn.b-cdn.net
BUNNY_TOKEN_KEY=your-token-key

# Bunny.net Stream
BUNNY_STREAM_LIBRARY_ID=your-library-id
BUNNY_STREAM_KEY=your-stream-key
BUNNY_STREAM_WEBHOOK_SECRET=your-webhook-secret

# ──────────────────────────────────────────────
# BACKBLAZE B2
# ──────────────────────────────────────────────
B2_KEY_ID=your-key-id
B2_APPLICATION_KEY=your-application-key
B2_BUCKET_ID=your-bucket-id
B2_BUCKET_NAME=your-bucket-name
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com

# ──────────────────────────────────────────────
# STRIPE
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX

# ──────────────────────────────────────────────
# PLATFORM SETTINGS
# ──────────────────────────────────────────────
PLATFORM_COMMISSION_PERCENT=20.0
MIN_SUBSCRIPTION_PRICE_CENTS=500
MAX_SUBSCRIPTION_PRICE_CENTS=50000
MIN_WITHDRAWAL_AMOUNT_CENTS=2000

# ──────────────────────────────────────────────
# TOTP (2FA)
# ──────────────────────────────────────────────
TOTP_ISSUER="Your App"

# ──────────────────────────────────────────────
# FILE UPLOAD LIMITS
# ──────────────────────────────────────────────
MAX_VIDEO_SIZE_BYTES=10737418240    # 10 GB
MAX_PHOTO_SIZE_BYTES=52428800       # 50 MB
MAX_AUDIO_SIZE_BYTES=524288000      # 500 MB

# ──────────────────────────────────────────────
# REQUEST PAYLOAD LIMITS
# ──────────────────────────────────────────────
# JSON payload limit for application/json requests (default: 16 MB)
# Increase if your endpoints need to accept large JSON payloads
# For file upload metadata, 16 MB should be sufficient
JSON_PAYLOAD_LIMIT=16777216        # 16 MB

# Form payload limit for multipart/form-data requests (default: 20 MB)
# Increase if you need to accept large form submissions
FORM_PAYLOAD_LIMIT=20971520        # 20 MB

# ──────────────────────────────────────────────
# NUXT PUBLIC CONFIG
# ──────────────────────────────────────────────
# SECURITY NOTE: NUXT_PUBLIC_* variables are bundled into client-side JS.
# Never put secrets here. Only use for public, non-sensitive values.

# Optional: Direct backend API URL for client-side requests (CSR)
# When set, client-side fetches bypass the Nitro proxy for lower latency.
# Leave empty (default) to use relative /api/v1 proxy - recommended for production.
# WARNING: Setting this exposes your backend URL in the client bundle.
# NUXT_PUBLIC_API_BASE=

# RATE LIMITING
# ──────────────────────────────────────────────
# Enable/disable rate limiting globally (default: true)
# Set to false to disable rate limiting entirely
# RATE_LIMIT_ENABLED=true